$pyNastran: version=msc
$pyNastran: punch=False
$pyNastran: encoding=utf-8
$EXECUTIVE CONTROL DECK
SOL 101
CEND
$CASE CONTROL DECK
DISPLACEMENT(PLOT,PRINT) = ALL
ESE(PLOT,PRINT) = ALL
FORCE(PLOT,PRINT) = ALL
GPFORCE(PLOT,PRINT) = ALL
MPCFORCES(PLOT,PRINT) = ALL
OLOAD(PLOT,PRINT) = ALL
SPCFORCES(PLOT,PRINT) = ALL
STRAIN(PLOT,PRINT) = ALL
STRESS(PLOT,PRINT) = ALL
SUBCASE 1
    LOAD = 2
    SPC = 3
BEGIN BULK
$PARAMS
PARAM     MYQUAD    MACN
$NODES
GRID           1              0.      0.      0.
GRID           2              1.      0.      0.
GRID           3              1.      0.      2.
GRID           4              0.      0.      2.
CQUAD4         1       1       1       2       3       4              0.
PCOMP          1
               3    .075      0.     YES       3    .075     45.     YES
               3    .075    -45.     YES       3    .075     90.     YES
$MATERIALS
MAT8           3   1.4+71000000.      .3 500000. 500000. 500000.      1.
$LOADS
FORCE          2       3              1.      0.      0.      1.
FORCE          2       4              1.      0.      0.      1.
$SPCs
SPC1           3  123456       1       2
