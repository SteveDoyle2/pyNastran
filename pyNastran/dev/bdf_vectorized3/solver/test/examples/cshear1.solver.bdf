$pyNastran: version=msc
$pyNastran: punch=False
$pyNastran: encoding=utf-8
$EXECUTIVE CONTROL DECK
SOL 101
CEND
$CASE CONTROL DECK
DISPLACEMENT(PLOT,PRINT) = ALL
ESE(PLOT,PRINT) = ALL
FORCE(PLOT,PRINT) = ALL
GPFORCE(PLOT,PRINT) = ALL
MPCFORCES(PLOT,PRINT) = ALL
OLOAD(PLOT,PRINT) = ALL
SPCFORCES(PLOT,PRINT) = ALL
STRAIN(PLOT,PRINT) = ALL
STRESS(PLOT,PRINT) = ALL
SUBCASE 1
    LOAD = 2
    SPC = 3
BEGIN BULK
$PARAMS
PARAM     GRDPNT       0
$NODES
GRID           1              0.      0.      0.
GRID           2              1.      0.      0.
GRID           3              1.      1.      0.
GRID           4              0.      0.      1.
GRID           5              1.      0.      1.
GRID           6              1.      1.      1.
CPENTA        10       4       1       2       3       4       5       6
PSOLID         4       3       0
$MATERIALS
MAT1           3    1.+7              .3      1.
$LOADS
FORCE          2       4              1.      0.      0.      1.
$SPCs
SPC1           3  123456       1       2       3
