$pyNastran: version=msc
$pyNastran: punch=False
$pyNastran: encoding=utf-8
$EXECUTIVE CONTROL DECK
SOL 101
CEND
$CASE CONTROL DECK
DISPLACEMENT(PLOT,PRINT) = ALL
SPCFORCES(PLOT,PRINT) = ALL
SUBCASE 1
    LOAD = 2
    MPC = 10
    SPC = 3
BEGIN BULK
$SPOINTS
SPOINT         1    THRU       4
CELAS4         1   1000.       1       2
CELAS4         2   1000.       3       4
$LOADS
SLOAD          2       2      1.
$SPCs
SPC1           3               1       4
$MPCs
MPC           10       2              1.       3             -1.
